{
  "name": "mblock-desktop",
  "version": "1.0.0",
  "description": "mBlock IDE desktop wrapper",
  "main": "main.js",
  "author": "mBlock Desktop",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --win --mac --linux"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "cc.mblock.ide.desktop",
    "productName": "mBlock IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "mBlock IDE"
    }
  }
}
